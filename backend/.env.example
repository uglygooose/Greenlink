# GreenLink local/dev runs against PostgreSQL by default.
# SQLite is not a supported runtime or migration target for the rebuild.
GREENLINK_ENV=development
GREENLINK_PROJECT_NAME=GreenLink API

# REQUIRED. Used for JWT signing. Generate a real value with: openssl rand -hex 32
GREENLINK_SECRET_KEY=replace-with-random-secret-via-openssl-rand-hex-32

GREENLINK_ACCESS_TOKEN_TTL_MINUTES=15
GREENLINK_REFRESH_TOKEN_TTL_DAYS=14
GREENLINK_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# REQUIRED. Postgres connection string. The value below matches the local
# docker-compose stack. Override for staging/production.
GREENLINK_DATABASE_URL=postgresql+psycopg://greenlink:greenlink@localhost:5432/greenlink
# Optional test override. Backend tests default to a PostgreSQL test database if this is unset.
# GREENLINK_TEST_DATABASE_URL=postgresql+psycopg://greenlink:greenlink@localhost:5432/greenlink_test

GREENLINK_REDIS_URL=redis://localhost:6379/0
GREENLINK_LOG_LEVEL=INFO
GREENLINK_OBJECT_STORAGE_ENDPOINT=http://localhost:9000
GREENLINK_OBJECT_STORAGE_BUCKET=greenlink-assets
GREENLINK_OBJECT_STORAGE_REGION=us-east-1

# REQUIRED. Object-storage credentials. Replace with real values per environment.
GREENLINK_OBJECT_STORAGE_ACCESS_KEY=replace-with-object-storage-access-key
GREENLINK_OBJECT_STORAGE_SECRET_KEY=replace-with-object-storage-secret-key

GREENLINK_SECURE_COOKIES=false
