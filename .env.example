# -----------------------------------------------------------------------------
# GreenLink environment template
# -----------------------------------------------------------------------------
# Copy this file to `.env` for local development.
# Never commit real secrets (database credentials, SECRET_KEY, API tokens).

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Preferred (Supabase / Postgres / any SQLAlchemy-supported DB)
# DATABASE_URL=postgresql+psycopg://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
DATABASE_URL=
DATABASE_URL_STRICT=0
PREFER_LOCAL_DB=0
FORCE_SQLITE=0
SQLITE_FALLBACK_URL=sqlite:///./greenlink.dev.db

MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=greenlink

# -----------------------------------------------------------------------------
# Auth + security
# -----------------------------------------------------------------------------
SECRET_KEY=CHANGE_ME
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional token guard for /metrics endpoint.
# Leave empty to disable token check.
METRICS_TOKEN=
# Optional override for local diagnostics only. In production-like runtimes,
# metrics access is fail-closed unless a token is configured.
METRICS_ALLOW_UNAUTHENTICATED=0

# Comma-separated CORS / trusted host lists.
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:3000
TRUSTED_HOSTS=*

# -----------------------------------------------------------------------------
# Runtime behavior
# -----------------------------------------------------------------------------
AUTO_MIGRATE=0
GREENLINK_LOG_LEVEL=INFO
FRONTEND_ASSET_CACHE_SECONDS=86400
HANDICAP_SA_MODE=disabled
# Optional local override for runtime classification.
GREENLINK_ASSUME_LOCAL=0

# Optional diagnostics metadata in /health.
RENDER_GIT_COMMIT=

# -----------------------------------------------------------------------------
# Rate limits
# -----------------------------------------------------------------------------
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW_SECONDS=60
SIGNUP_RATE_LIMIT=8
SIGNUP_RATE_WINDOW_SECONDS=300
IMPORT_RATE_LIMIT=20
IMPORT_RATE_WINDOW_SECONDS=300

# -----------------------------------------------------------------------------
# Password policy
# -----------------------------------------------------------------------------
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_LETTER=1
PASSWORD_REQUIRE_DIGIT=1
PASSWORD_REQUIRE_UPPER=0
PASSWORD_REQUIRE_SPECIAL=0

# -----------------------------------------------------------------------------
# Demo data and demo admin seed (optional)
# -----------------------------------------------------------------------------
DEMO_SEED_DATA=0
DEMO_SEED_DATA_FORCE=0

DEMO_SEED_ADMIN=0
DEMO_ADMIN_EMAIL=admin@umhlali.com
DEMO_ADMIN_PASSWORD=change_me
DEMO_ADMIN_NAME=Admin
DEMO_ADMIN_FORCE_RESET=0
# Hard safety gate for production-like environments.
DEMO_SEED_ADMIN_ALLOW_PRODUCTION=0

# -----------------------------------------------------------------------------
# Multi-tenant bootstrap (optional)
# -----------------------------------------------------------------------------
GREENLINK_BOOTSTRAP=0
GREENLINK_BOOTSTRAP_FORCE_RESET=0
GREENLINK_SUPER_ADMIN_EMAIL=greenlinkgolfsa@gmail.com
GREENLINK_SUPER_ADMIN_PASSWORD=change_me
GREENLINK_DEFAULT_CLUB_NAME=Umhlali Country Club
GREENLINK_DEFAULT_CLUB_SLUG=umhlali
GREENLINK_DEFAULT_CLUB_ADMIN_EMAIL=admin@umhlali.com
GREENLINK_DEFAULT_CLUB_ADMIN_PASSWORD=change_me

# -----------------------------------------------------------------------------
# Club branding defaults (can also be stored in DB club_settings)
# -----------------------------------------------------------------------------
CLUB_NAME=GreenLink
CLUB_SLUG=greenlink
CLUB_LOGO_URL=/frontend/assets/logo.png
CLUB_CURRENCY_SYMBOL=R
CLUB_MEMBER_LABEL=Member
CLUB_VISITOR_LABEL=Affiliated Visitor
CLUB_NON_AFFILIATED_LABEL=Visitor (No HNA)
# JSON or comma-separated values
CLUB_HOME_CLUB_KEYWORDS=greenlink
CLUB_SUGGESTED_HOME_CLUBS=GreenLink
CLUB_CONFIG_CACHE_TTL_SECONDS=60

# -----------------------------------------------------------------------------
# Umhlali operational import bootstrap (optional)
# -----------------------------------------------------------------------------
UMHLALI_OPERATIONAL_SYNC=0
UMHLALI_OPERATIONAL_SYNC_FORCE=0
# If set, overrides default sample input directory resolution.
UMHLALI_OPERATING_INPUT_DIR=
